{
  "name": "peanut-vision",
  "version": "1.0.0",
  "description": "PeanutVision — 땅콩 검사 비전 시스템",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:dir": "electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.peanut-factory.peanut-vision",
    "productName": "PeanutVision",
    "copyright": "Copyright © 2025 Peanut Factory",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "resources/PeanutVision.Api",
        "to": "PeanutVision.Api",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PeanutVision",
      "installerIcon": "build-resources/installer-icon.ico",
      "uninstallerIcon": "build-resources/installer-icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
